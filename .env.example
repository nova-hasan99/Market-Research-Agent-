# Copy this file to .env and fill in your real keys.
# Never commit .env to version control.

# ── Price data providers ─────────────────────────────────────────────────────
TWELVE_DATA_KEY=
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
POLYGON_KEY=

# ── AI summary providers ─────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── News sentiment ───────────────────────────────────────────────────────────
NEWSAPI_KEY=

# ── Supabase (required for auth + dashboard) ─────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ACCESS_TOKEN=your-personal-access-token-here

# ── Super Admin credentials (used by scripts/setup_db.py to create the admin account) ──
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
