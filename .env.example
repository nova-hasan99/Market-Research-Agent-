# Copy this file to .env and fill in your real keys.
# Never commit .env to version control.
#
# REQUIRED = system needs at least one from the group
# OPTIONAL = system works fine without it, but adds more accuracy when provided

# ── Price data (REQUIRED: at least one) ──────────────────────────────────────
TWELVE_DATA_KEY=
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
POLYGON_KEY=

# ── AI summary (OPTIONAL: falls back to rule-based summary if none set) ──────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── News sentiment (OPTIONAL: system works without, score still calculates) ──
NEWSAPI_KEY=

# ── Supabase (REQUIRED for auth + dashboard) ─────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ACCESS_TOKEN=your-personal-access-token-here

# ── Super Admin (REQUIRED for setup_db.py) ───────────────────────────────────
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# ── Retail Sentiment APIs (ALL OPTIONAL) ─────────────────────────────────────
# System works perfectly without these.
# When provided: adds retail trader positioning data (contrarian signals).
# Priority order: OANDA first, then IG if OANDA not available.
# Note: OANDA not available in some countries (e.g. Bangladesh).
# Note: IG API requires a live trading account.
# Note: TradingEconomics is a paid service.
# Leave blank if unavailable - the system will skip these sections gracefully.

OANDA_API_KEY=
OANDA_ACCOUNT_ID=

IG_API_KEY=

TRADINGECONOMICS_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
